backend/document_request/document_checker.py
def check_required_documents(classification: dict):

    print("[DOC CHECK] Checking required documents")

    if classification["type"] == "service":
        return [
            "contract",
            "service_order",
            "payment_order"
        ]
    else:
        return [
            "purchase_order",
            "supply_contract"
        ]
