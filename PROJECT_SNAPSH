backend/classifiers/service_classifier.py
def classify_service(parsed_invoice: dict):

    print("[CLASSIFIER] Classifying service")

    description = parsed_invoice.get("description", "").lower()

    if "product" in description:
        return {"type": "product"}
    else:
        return {"type": "service"}
