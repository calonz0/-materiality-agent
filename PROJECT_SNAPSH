from ingestion.invoice_parser import parse_invoice
from classifiers.service_classifier import classify_service
from document_request.document_checker import check_required_documents
from context.context_builder import build_context
from engines.materiality_engine import run_materiality_analysis
from generators.output_generator import generate_output


def run_materiality_process(client_id: str, invoice_data: dict):

    print("[FLOW] START")

    parsed_invoice = parse_invoice(invoice_data)
    classification = classify_service(parsed_invoice)
    required_docs = check_required_documents(classification)
    context = build_context(client_id, parsed_invoice, classification)
    materiality = run_materiality_analysis(context)

    return generate_output(
        parsed_invoice,
        classification,
        required_docs,
        context,
        materiality
    )
