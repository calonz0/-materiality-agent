from engines.llm_client import LLMClient

llm = LLMClient()


def run_materiality_analysis(context: dict):

    print("[ENGINE] Running materiality analysis")

    prompt = f"""
    Analyze this operation:

    Client: {context['client_id']}
    Type: {context['classification']}
    Description: {context['invoice'].get('description')}
    """

    llm_response = llm.generate(prompt)

    return {
        "analysis": llm_response["response"],
        "status": "generated"
    }
