def parse_invoice(invoice_data: dict):

    print("[PARSER] Parsing invoice")

    return {
        "raw": invoice_data,
        "amount": invoice_data.get("amount", 0),
        "description": invoice_data.get("description", ""),
        "client": invoice_data.get("client", "")
    }
